#!/usr/bin/env bash

# Pre-commit safety checks for staged files.

MAX_FILE_SIZE=1048576
BLOCKED=0

echo "Running pre-commit safety checks..."

mapfile -t STAGED_FILES < <(
  git diff --cached --name-only --diff-filter=ACM
)

if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
  echo "No staged files to inspect."
  exit 0
fi

for file in "${STAGED_FILES[@]}"; do
  # Check the staged content for an AWS-style access key.
  if git show ":$file" 2>/dev/null |
    grep -aEq 'AKIA[0-9A-Z]{16}'; then
    echo "BLOCKED: Possible AWS access key detected in $file"
    BLOCKED=1
  fi

  # Check the staged content for other secret-like assignments.
  if git show ":$file" 2>/dev/null |
    grep -aEiq '(password|passwd|secret|api[_-]?key|token)[[:space:]]*[:=]'; then
    echo "BLOCKED: Possible hardcoded secret detected in $file"
    BLOCKED=1
  fi

  # Check the size of the staged version of the file.
  FILE_SIZE=$(git cat-file -s ":$file" 2>/dev/null || echo 0)

  if [ "$FILE_SIZE" -gt "$MAX_FILE_SIZE" ]; then
    echo "BLOCKED: $file is larger than 1 MB"
    BLOCKED=1
  fi
done

if [ "$BLOCKED" -ne 0 ]; then
  echo
  echo "Commit rejected. Remove the risky content, stage the fix, and try again."
  exit 1
fi

echo "Pre-commit safety checks passed."
exit 0